a:["$","$L7","item-2",{"value":"item-2","children":[["$","$L15",null,{"className":"text-left","children":"Can I use the free version for my campaigns?"}],["$","$L16",null,{"children":"Yes, the free version includes all generators with premade cities and worlds, but no data persistence, so once you leave the page, everything will be lost. You can export generations as CSV/Image files, though."}]]}]
b:["$","$L7","item-3",{"value":"item-3","children":[["$","$L15",null,{"className":"text-left","children":"What's included in the Premium subscription plans?"}],["$","$L16",null,{"children":["Premium plans include all current and future generators, custom world/city creation, party creation, data persistence, permalink and generation. Logging in gives you a free trial. You can read more about it on the"," ",["$","$L17",null,{"href":"/web/pricing","className":"text-primary underline","children":"pricing page"}],"."]}]]}]
c:["$","$L7","item-4",{"value":"item-4","children":[["$","$L15",null,{"className":"text-left","children":"Can I export generated content to my VTT?"}],["$","$L16",null,{"children":"Yes, battle maps can be exported in formats compatible with popular virtual tabletop platforms. Other generated content can be exported as CSV files for easy integration."}]]}]
d:["$","$L7","item-5",{"value":"item-5","children":[["$","$L15",null,{"className":"text-left","children":"How accurate is the encounter balancing?"}],["$","$L16",null,{"children":"Encounters are balanced using official D&D 5e 2024 guidelines, taking into account the number of PCs in the party and their levels."}]]}]
e:["$","$L7","item-6",{"value":"item-6","children":[["$","$L15",null,{"className":"text-left","children":"Can I create custom content or modify the generators?"}],["$","$L16",null,{"children":"Currently, the generators use official D&D 5e data. Custom world and city creation is available in all Premium plans. Creating custom spells, monsters, and magic items is planned for future updates. You can customize the generator settings to your heart's content."}]]}]
